#!/usr/bin/env bash
# Git commit-msg hook for OscarPoolVibes
# Validates conventional commit format with issue references.
#
# Format: <type>(<scope>): <description> (#<issue>)
#
# Types:  feat, fix, docs, test, refactor, chore, style, perf
# Scopes: pools, scoring, auth, leaderboard, results, admin, a11y, seo, infra, ui, design
#
# Examples:
#   feat(pools): add invite management UI (#42)
#   fix(scoring): handle zero-multiplier edge case (#15)
#   docs: update SCHEMA.md with soft delete fields (#30)
#   chore(infra): upgrade Next.js to 15.1 (#8)
#
# Install: run `bash scripts/install-hooks.sh` from the project root.

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits and revert commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge |Revert )"; then
  exit 0
fi

# Allowed types and scopes
TYPES="feat|fix|docs|test|refactor|chore|style|perf"
SCOPES="pools|scoring|auth|leaderboard|results|admin|a11y|seo|infra|ui|design"

# Pattern: type(scope): description (#issue)
# Scope is optional, issue reference is required
PATTERN="^($TYPES)(\(($SCOPES)\))?: .+ \(#[0-9]+\)$"

# Check first line only
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)

if ! echo "$FIRST_LINE" | grep -qE "$PATTERN"; then
  echo ""
  echo "ERROR: Commit message does not match conventional commit format."
  echo ""
  echo "  Expected: <type>(<scope>): <description> (#<issue>)"
  echo ""
  echo "  Types:  $TYPES"
  echo "  Scopes: $SCOPES (optional)"
  echo ""
  echo "  Examples:"
  echo "    feat(pools): add invite management UI (#42)"
  echo "    fix(scoring): handle zero-multiplier edge case (#15)"
  echo "    docs: update SCHEMA.md (#30)"
  echo ""
  echo "  Your message: $FIRST_LINE"
  echo ""
  echo "  Tip: Every commit must reference a GitHub Issue number."
  echo ""
  exit 1
fi

# Check description length (max 72 chars for first line)
if [ ${#FIRST_LINE} -gt 72 ]; then
  echo ""
  echo "ERROR: Commit message first line is too long (${#FIRST_LINE} chars, max 72)."
  echo ""
  echo "  Your message: $FIRST_LINE"
  echo ""
  exit 1
fi
